function Environment.Functions:Exit()
    for _, v in next, ServiceConnections do v:Disconnect() end
    if Environment.FOVCircle.Remove then Environment.FOVCircle:Remove() end
    getgenv().Aimbot.Functions = nil
    getgenv().Aimbot = nil
    Load = nil; GetClosestPlayer = nil; CancelLock = nil
end

--// ESP Logic
local function removeESP(player)
    if espHighlights[player] then espHighlights[player]:Destroy() espHighlights[player] = nil end
    if espBillboards[player] then espBillboards[player]:Destroy() espBillboards[player] = nil end
end

local function makeNameTag(player, char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bb = Instance.new("BillboardGui")
    bb.Name = "ESP_BB" bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 150, 0, 40)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.Adornee = hrp bb.Parent = hrp
    local label = Instance.new("TextLabel", bb)
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0,0,0)
    label.Font = Enum.Font.GothamBold
    label.TextScaled = true
    label.Text = player.Name
    espBillboards[player] = bb
    
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not espEnabled or not espBillboards[player] or not hrp.Parent then 
            if conn then conn:Disconnect() end
            return 
        end
        local lc = LocalPlayer.Character
        local lh = lc and lc:FindFirstChild("HumanoidRootPart")
        if not lh then return end
        local dist = math.floor((hrp.Position - lh.Position).Magnitude)
        local t = (espShowNames and player.Name or "") .. (espShowDist and (" [" .. dist .. "m]") or "")
        label.Text = t
    end)
end

local function applyESP(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    removeESP(player)
    
    local h = Instance.new("Highlight")
    h.FillColor    = espFillColor
    h.OutlineColor = espOutlineColor
    h.FillTransparency    = 0.35
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = char h.Parent = char
    espHighlights[player] = h
    makeNameTag(player, char)
end

local function enableESP()
    espEnabled = true
    for _, p in ipairs(Players:GetPlayers()) do applyESP(p) end
end

local function disableESP()
    espEnabled = false
    for p in pairs(espHighlights) do removeESP(p) end
end

