local function teleportToPlayer(player, icon)
    local tc = player.Character
    local th = tc and tc:FindFirstChild("HumanoidRootPart")
    if not th then
        Rayfield:Notify({ Title = "Niet bereikbaar", Content = player.Name .. " heeft geen karakter.", Duration = 3 })
        return
    end
    local mc = LocalPlayer.Character
    local mh = mc and mc:FindFirstChild("HumanoidRootPart")
    if not mh then return end
    mh.CFrame = th.CFrame + Vector3.new(3, 0, 0)
    Rayfield:Notify({ Title = icon .. " Geteleporteerd!", Content = "Je staat nu naast " .. player.Name, Duration = 3 })
end

local function addTPButton(player)
    if player == LocalPlayer then return end
    if addedTPPlayers[player.Name] then return end
    addedTPPlayers[player.Name] = true
    tpIconIndex = (tpIconIndex % #playerIcons) + 1
    local icon = playerIcons[tpIconIndex]
    TPTab:CreateButton({
        Name = icon .. "  " .. player.Name,
        Callback = function()
            local target = Players:FindFirstChild(player.Name)
            if not target then
                Rayfield:Notify({ Title = "Niet in server", Content = player.Name .. " heeft de server verlaten.", Duration = 3 })
                return
            end
            teleportToPlayer(target, icon)
        end,
    })
end

