for _, location in ipairs(Locations) do
    local loc = location
    TeleportTab:CreateButton({
        Name     = loc.Name,
        Callback = function() teleportTo(loc) end,
    })
end

-- ── Directe teleport per speler ──────────────────────────────
TeleportTab:CreateSection("🧍 Teleport naar Speler")
TeleportTab:CreateLabel("Druk op een naam om direct naar die speler te gaan.")

local playerIcons = {"🏍️", "🚴", "🛵", "🤙", "🏁", "💨", "👑", "🔥"}

-- Bijhouden welke knoppen er zijn zodat we ze kunnen verwijderen bij refresh
local playerTPButtons = {}  -- [knop] = true

local function clearPlayerButtons()
    for btn, _ in pairs(playerTPButtons) do
        pcall(function() btn:Destroy() end)
    end
    playerTPButtons = {}
end

local function buildPlayerButtons()
    clearPlayerButtons()
    local idx = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            idx = (idx % #playerIcons) + 1
            local icon = playerIcons[idx]
            local player = p
            local btn = TeleportTab:CreateButton({
                Name = icon .. "  " .. player.Name,
                Callback = function()
                    local targetChar = player.Character
                    local targetHRP  = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                    if not targetHRP then
                        Rayfield:Notify({ Title = "Niet bereikbaar", Content = player.Name .. " heeft geen karakter.", Duration = 3 })
                        return
                    end
                    local myChar = LocalPlayer.Character
                    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    if not myHRP then return end
                    myHRP.CFrame = targetHRP.CFrame + Vector3.new(3, 0, 0)
                    Rayfield:Notify({ Title = icon .. "  Geteleporteerd!", Content = "Je staat nu naast " .. player.Name, Duration = 3 })
                end,
            })
            if btn then playerTPButtons[btn] = true end
        end
    end
end

-- Ververs-knop
TeleportTab:CreateButton({
    Name = "🔄  Ververs spelerslijst",
    Callback = function()
        buildPlayerButtons()
        local count = 0
        for _ in pairs(playerTPButtons) do count = count + 1 end
        Rayfield:Notify({
            Title   = "🔄 Lijst ververst",
            Content = count .. " speler(s) gevonden in de server.",
            Duration = 3,
        })
    end,
})

-- Eerste keer laden
buildPlayerButtons()

-- Auto-refresh als iemand joint of verlaat
Players.PlayerAdded:Connect(function()
    task.wait(1)
    buildPlayerButtons()
end)
Players.PlayerRemoving:Connect(function()
    task.wait(0.2)
    buildPlayerButtons()
end)

