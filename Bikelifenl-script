--  TAB 3 – NOCLIP
-- ════════════════════════════════════════════════════════════
local NoclipTab = Window:CreateTab("👻 Noclip", 4483362458)

local noclipEnabled = false
local noclipConn

local function setNoclip(state)
    noclipEnabled = state
    if state then
        noclipConn = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end)
    else
        if noclipConn then noclipConn:Disconnect() noclipConn = nil end
        -- Zet collision terug
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end

NoclipTab:CreateToggle({
    Name        = "Noclip inschakelen",
    CurrentValue= false,
    Flag        = "NoclipToggle",
    Callback    = function(state)
        setNoclip(state)
        Rayfield:Notify({
            Title   = state and "👻 Noclip AAN" or "👻 Noclip UIT",
            Content = state and "Je loopt nu door alles heen." or "Collision is terug.",
            Duration = 3,
        })
    end,
})

NoclipTab:CreateSection("Info")
NoclipTab:CreateLabel("Met noclip loop je door muren, vloeren en objecten.")
NoclipTab:CreateLabel("Combineer met Vliegen voor maximale vrijheid.")

LocalPlayer.CharacterAdded:Connect(function()
    if noclipEnabled then task.wait(0.5) setNoclip(true) end
end)

