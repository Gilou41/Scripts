--  TAB 5 – ESP
-- ════════════════════════════════════════════════════════════
local ESPTab = Window:CreateTab("👁️ ESP", 4483362458)

local espEnabled    = false
local espHighlights = {}
local espBillboards = {}
local espColor      = Color3.fromRGB(255, 50, 50)
local espShowNames  = true
local espShowDist   = true

local function removeESP(player)
    if espHighlights[player] then espHighlights[player]:Destroy() espHighlights[player] = nil end
    if espBillboards[player] then espBillboards[player]:Destroy() espBillboards[player] = nil end
end

local function makeNameTag(player, char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bb = Instance.new("BillboardGui")
    bb.Name = "ESP_Billboard"
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 140, 0, 40)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.Adornee = hrp
    bb.Parent  = hrp
    local label = Instance.new("TextLabel", bb)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextScaled = true
    label.Text = player.Name
    espBillboards[player] = bb
    RunService.Heartbeat:Connect(function()
        if not espEnabled or not espBillboards[player] then return end
        local localChar = LocalPlayer.Character
        local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
        if not localHRP or not hrp.Parent then return end
        local dist = math.floor((hrp.Position - localHRP.Position).Magnitude)
        local nameText = espShowNames and player.Name or ""
        local distText = espShowDist  and (" [" .. dist .. "m]") or ""
        label.Text = nameText .. distText
    end)
end

local function applyESP(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local h = Instance.new("Highlight")
    h.FillColor    = espColor
    h.OutlineColor = Color3.new(1, 1, 1)
    h.FillTransparency    = 0.4
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = char
    h.Parent  = char
    espHighlights[player] = h
    makeNameTag(player, char)
    player.CharacterAdded:Connect(function(newChar)
        task.wait(0.2)
        if espEnabled then
            if espHighlights[player] then espHighlights[player]:Destroy() end
            if espBillboards[player] then espBillboards[player]:Destroy() end
            applyESP(player)
        end
    end)
end

local function enableESP()
    espEnabled = true
    for _, p in ipairs(Players:GetPlayers()) do applyESP(p) end
    Players.PlayerAdded:Connect(function(p)
        if espEnabled then task.wait(1) applyESP(p) end
    end)
end

local function disableESP()
    espEnabled = false
    for p, _ in pairs(espHighlights) do removeESP(p) end
end

ESPTab:CreateToggle({ Name = "ESP inschakelen", CurrentValue = false, Flag = "ESPToggle",
    Callback = function(state) if state then enableESP() else disableESP() end end })
ESPTab:CreateColorPicker({ Name = "ESP Kleur", Color = Color3.fromRGB(255,50,50), Flag = "ESPColor",
    Callback = function(color)
        espColor = color
        for _, h in pairs(espHighlights) do h.FillColor = color end
    end })
ESPTab:CreateToggle({ Name = "Namen tonen",   CurrentValue = true, Flag = "ESPNames", Callback = function(s) espShowNames = s end })
ESPTab:CreateToggle({ Name = "Afstand tonen", CurrentValue = true, Flag = "ESPDist",  Callback = function(s) espShowDist  = s end })
ESPTab:CreateSection("Info")
ESPTab:CreateLabel("ESP werkt door muren heen (AlwaysOnTop).")
ESPTab:CreateLabel("Naamtags tonen speler + afstand in meters.")

Players.PlayerRemoving:Connect(function(p) removeESP(p) end)

